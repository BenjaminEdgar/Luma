<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:Luma.App.Controls"
             x:Class="Luma.App.App"
             RequestedThemeVariant="Light">
    <!-- Default theme: Blue (white → blue). Colorful applied at runtime via LumaTheme.Apply. -->

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentStart">#2563EB</Color>
            <Color x:Key="AccentEnd">#38BDF8</Color>
            <Color x:Key="AccentSoft">#3B82F6</Color>
            <Color x:Key="InkPanel">#F0F7FF</Color>
            <Color x:Key="TextBright">#0F172A</Color>
            <Color x:Key="TextBody">#1E293B</Color>
            <Color x:Key="TextMuted">#64748B</Color>

            <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#3B82F6" />
            <SolidColorBrush x:Key="AccentEndBrush" Color="#38BDF8" />
            <SolidColorBrush x:Key="TextBrightBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="TextBodyBrush" Color="#1E293B" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />

            <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#2563EB" Offset="0" />
                <GradientStop Color="#3B82F6" Offset="0.45" />
                <GradientStop Color="#38BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AccentGradientBright" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#3B82F6" Offset="0" />
                <GradientStop Color="#60A5FA" Offset="0.45" />
                <GradientStop Color="#7DD3FC" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="StarMarkBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#93C5FD" Offset="0" />
                <GradientStop Color="#2563EB" Offset="0.4" />
                <GradientStop Color="#3B82F6" Offset="0.75" />
                <GradientStop Color="#38BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="UserBubbleBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#F8FBFF" Offset="0" />
                <GradientStop Color="#DBEAFE" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AssistantBubbleBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#FFFFFFFF" Offset="0" />
                <GradientStop Color="#F0F7FF" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="StreamEnergyBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#002563EB" Offset="0" />
                <GradientStop Color="#FF2563EB" Offset="0.35" />
                <GradientStop Color="#FF38BDF8" Offset="0.75" />
                <GradientStop Color="#0038BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="ModuleInsetBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#88FFFFFF" Offset="0" />
                <GradientStop Color="#00FFFFFF" Offset="0.4" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="SplitBrainBorderBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#AA2563EB" Offset="0" />
                <GradientStop Color="#AA38BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="PanelFillBrush" StartPoint="0%,0%" EndPoint="50%,100%">
                <GradientStop Color="#FFFFFFFF" Offset="0" />
                <GradientStop Color="#FFF0F7FF" Offset="0.55" />
                <GradientStop Color="#FFE0EFFF" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="SurfaceGlassBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="QuietGlassBrush" Color="#F0F7FF" />
            <SolidColorBrush x:Key="ComposeFillBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#BFDBFE" />
            <SolidColorBrush x:Key="PanelBorderBusyBrush" Color="#93C5FD" />
            <SolidColorBrush x:Key="PanelBorderWritingBrush" Color="#34D399" />
            <LinearGradientBrush x:Key="HeaderSheenBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#002563EB" Offset="0" />
                <GradientStop Color="#882563EB" Offset="0.35" />
                <GradientStop Color="#8838BDF8" Offset="0.7" />
                <GradientStop Color="#0038BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="PrismEdgeBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#002563EB" Offset="0" />
                <GradientStop Color="#CC2563EB" Offset="0.3" />
                <GradientStop Color="#AA38BDF8" Offset="0.7" />
                <GradientStop Color="#0038BDF8" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="PrismEdgeVerticalBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#882563EB" Offset="0" />
                <GradientStop Color="#00BFDBFE" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ComposeBorderBrush" Color="#DBEAFE" />
            <LinearGradientBrush x:Key="ComposeBorderListeningBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#2563EB" Offset="0" />
                <GradientStop Color="#3B82F6" Offset="0.5" />
                <GradientStop Color="#38BDF8" Offset="1" />
            </LinearGradientBrush>
            <RadialGradientBrush x:Key="DockGlowBrush" Center="50%,50%" GradientOrigin="45%,40%">
                <GradientStop Color="#CC2563EB" Offset="0" />
                <GradientStop Color="#883B82F6" Offset="0.45" />
                <GradientStop Color="#4438BDF8" Offset="0.7" />
                <GradientStop Color="#00000000" Offset="1" />
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="OrbTopBrush" Center="15%,10%" GradientOrigin="15%,10%">
                <GradientStop Color="#552563EB" Offset="0" />
                <GradientStop Color="#00000000" Offset="1" />
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="OrbMidBrush" Center="80%,40%" GradientOrigin="80%,40%">
                <GradientStop Color="#3338BDF8" Offset="0" />
                <GradientStop Color="#00000000" Offset="1" />
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="OrbBottomBrush" Center="50%,95%" GradientOrigin="50%,95%">
                <GradientStop Color="#28BFDBFE" Offset="0" />
                <GradientStop Color="#00000000" Offset="1" />
            </RadialGradientBrush>
            <ConicGradientBrush x:Key="ThinkingBrush" Center="50%,50%">
                <GradientStop Color="#002563EB" Offset="0" />
                <GradientStop Color="#FF2563EB" Offset="0.45" />
                <GradientStop Color="#FF38BDF8" Offset="0.85" />
                <GradientStop Color="#002563EB" Offset="1" />
            </ConicGradientBrush>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Primary: brand gradient (violet → cyan), flat interaction. -->
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentGradient}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentGradientBright}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentGradient}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Button.accent:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#D4D0F0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F2F4FF" />
            <Setter Property="Foreground" Value="#080F23" />
        </Style>
        <Style Selector="Button.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E8E4F8" />
        </Style>

        <!-- Secondary: white + soft violet rim (brand board secondary button). -->
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8F7FF" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#080F23" />
        </Style>
        <Style Selector="Button.outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F2F4FF" />
        </Style>

        <Style Selector="Border.statuspill">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E4F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="11,5" />
        </Style>
        <Style Selector="Border.statuspill.plan">
            <Setter Property="Background" Value="#F5F0FF" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
            <Setter Property="BoxShadow" Value="0 0 14 0 #332563EB" />
        </Style>

        <!-- Soft pill chips. -->
        <Style Selector="Button.chip">
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#E8E4F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F2F4FF" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
            <Setter Property="Foreground" Value="#080F23" />
        </Style>
        <Style Selector="Button.chip:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Halt square: flat danger fill. -->
        <Style Selector="Button.stop">
            <Setter Property="Background" Value="#FFE8EA" />
            <Setter Property="Foreground" Value="#C42B3A" />
            <Setter Property="BorderBrush" Value="#EE8890" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.stop:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#FF5D6E" />
            <Setter Property="BorderBrush" Value="#FF5D6E" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.stop:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E5455A" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.msgcopy">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#E8E4F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.bubble:pointerover Button.msgcopy">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.msgcopy:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.codecopy">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.codecopy:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Dock: soft restrained breath. -->
        <Style Selector="Border.dockglow">
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="Effect"><BlurEffect Radius="12" /></Setter>
            <Style.Animations>
                <Animation Duration="0:0:3.2" IterationCount="Infinite" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.28" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.55" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.dockring">
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <!-- Dual geometric lattice: different speeds for parallax (phase loop = CellSize). -->
        <Style Selector="c|GeometricPattern.geopattern">
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <!-- Far layer: large diagonal hatch, slow crawl. -->
        <Style Selector="c|GeometricPattern.geopattern.slow">
            <Style.Animations>
                <Animation Duration="0:1:12" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Phase" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Phase" Value="32" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Near layer: denser dots, faster opposite shear. -->
        <Style Selector="c|GeometricPattern.geopattern.fast">
            <Style.Animations>
                <Animation Duration="0:0:36" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Phase" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Phase" Value="18" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.ambientorb">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Effect"><BlurEffect Radius="32" /></Setter>
        </Style>
        <Style Selector="Border.prismrim">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Border.prismrim.busy">
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="Ellipse.thinkingring">
            <Setter Property="Width" Value="15" /><Setter Property="Height" Value="15" />
            <Setter Property="Fill" Value="Transparent" /><Setter Property="Stroke" Value="{DynamicResource ThinkingBrush}" />
            <Setter Property="StrokeThickness" Value="2.2" /><Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="RenderTransform"><RotateTransform /></Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.85" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Energy stream caret (kept class streamcursor for product DNA). -->
        <Style Selector="TextBlock.streamcursor">
            <Setter Property="Foreground" Value="#FF7C5CFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Style.Animations>
                <Animation Duration="0:0:0.55" IterationCount="Infinite" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.streamcursor">
            <Setter Property="Background" Value="{DynamicResource StreamEnergyBrush}" />
            <Setter Property="CornerRadius" Value="1.5" />
            <Setter Property="Width" Value="3" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="1,2,0,0" />
            <Setter Property="BoxShadow" Value="0 0 14 0 #A5B4FC" />
            <Style.Animations>
                <Animation Duration="0:0:0.55" IterationCount="Infinite" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- The Luma loading line: aurora energy bar that breathes under streaming content. -->
        <Style Selector="Border.streamshimmer">
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource StreamEnergyBrush}" />
            <Setter Property="Margin" Value="0,8,0,2" />
            <Setter Property="BoxShadow" Value="0 0 12 0 #2E2563EB" />
            <Setter Property="Opacity" Value="0.8" />
            <Style.Animations>
                <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.9" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.turnmeta">
            <Setter Property="Background" Value="#CCFFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MaxWidth" Value="360" />
        </Style>
        <Style Selector="Border.turnrail">
            <Setter Property="Width" Value="46" />
            <Setter Property="Padding" Value="0,3,0,0" />
        </Style>
        <Style Selector="Ellipse.raildot">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Fill" Value="#4F46E5" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
        <Style Selector="TextBlock.raillabel">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MaxWidth" Value="42" />
            <Setter Property="LineHeight" Value="11" />
        </Style>

        <!-- Shared module chrome (question / split / audit / live pair). -->
        <Style Selector="Border.module">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceGlassBrush}" />
            <Setter Property="BoxShadow" Value="0 8 22 0 #22000000, 0 0 18 0 #1A000000, inset 0 1 0 0 #AAFFFFFF" />
        </Style>

        <!-- Clarifying question: violet module nested in the assistant bubble. -->
        <Style Selector="Border.questioncard">
            <Setter Property="Background" Value="{DynamicResource SurfaceGlassBrush}" />
            <Setter Property="BorderBrush" Value="#C7D2FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="13,11" />
            <Setter Property="BoxShadow" Value="0 10 28 0 #EEF2FF, inset 0 1 0 0 #CCFFFFFF" />
            <Style.Animations>
                <Animation Duration="0:0:0.22" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="TranslateTransform.Y" Value="4" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="TranslateTransform.Y" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.questionbadge">
            <Setter Property="Background" Value="{DynamicResource AccentGradient}" />
            <Setter Property="BoxShadow" Value="0 4 14 0 #E2E8F0" />
        </Style>
        <Style Selector="TextBlock.questionprompt">
            <Setter Property="FontSize" Value="15.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="LineHeight" Value="23" />
        </Style>
        <Style Selector="Button.qchoice">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MaxWidth" Value="280" />
        </Style>
        <Style Selector="Button.qchoice:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="Button.qchoice:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="BorderBrush" Value="#4F46E5" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.qskip">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.qskip:pointerover">
            <Setter Property="Foreground" Value="#334155" />
        </Style>
        <!-- In-chat screenshot chip (keep small — full-size previews look oversized in bubbles). -->
        <Style Selector="Border.chatimage">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxWidth" Value="128" />
            <Setter Property="MaxHeight" Value="80" />
            <Setter Property="BoxShadow" Value="0 4 14 0 #1A000000" />
        </Style>
        <Style Selector="Border.chatimagelabel">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <!-- Larger dual explain actions: room for title + short how-to line. -->
        <Style Selector="Button.actioncard">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.actioncard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E0E7FF" />
            <Setter Property="BorderBrush" Value="#A5B4FC" />
        </Style>

        <!-- Signal thinking dots for pending messages. -->
        <Style Selector="Ellipse.thinkdot">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="#FF7C5CFF" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Ellipse.thinkdot.d1">
            <Style.Animations>
                <Animation Duration="0:0:1.05" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="30%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="-3" /></KeyFrame>
                    <KeyFrame Cue="60%"><Setter Property="Opacity" Value="0.35" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.thinkdot.d2">
            <Style.Animations>
                <Animation Duration="0:0:1.05" IterationCount="Infinite" Delay="0:0:0.14">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="30%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="-3" /></KeyFrame>
                    <KeyFrame Cue="60%"><Setter Property="Opacity" Value="0.35" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.thinkdot.d3">
            <Style.Animations>
                <Animation Duration="0:0:1.05" IterationCount="Infinite" Delay="0:0:0.28">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="30%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="-3" /></KeyFrame>
                    <KeyFrame Cue="60%"><Setter Property="Opacity" Value="0.35" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Legacy dots kept for older templates. -->
        <Style Selector="Ellipse.dot">
            <Setter Property="Width" Value="6" /><Setter Property="Height" Value="6" />
            <Setter Property="Fill" Value="#A5B4FC" /><Setter Property="Opacity" Value="0.25" />
        </Style>
        <Style Selector="Ellipse.dot">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="55%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.dot2">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.18">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="55%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse.dot3">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.36">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="55%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Chat cards: clean white assistant / lavender-tinted user, soft asymmetric tails. -->
        <Style Selector="Border.bubble">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#ECE8FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18,18,18,6" />
            <Setter Property="Padding" Value="15,12" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="BoxShadow" Value="0 6 18 0 #0E2563EB, 0 1 2 0 #06080F23" />
        </Style>
        <Style Selector="Border.bubble">
            <Style.Animations>
                <Animation Duration="0:0:0.16" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="TranslateTransform.Y" Value="4" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="TranslateTransform.Y" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.bubble.user">
            <Setter Property="Background" Value="{DynamicResource UserBubbleBrush}" />
            <Setter Property="BorderBrush" Value="#E4DDFB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18,18,6,18" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="BoxShadow" Value="0 6 18 0 #0E2563EB, 0 1 2 0 #06080F23" />
        </Style>
        <Style Selector="Border.bubble.error">
            <Setter Property="Background" Value="#FEF2F2" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 1 2 0 #0A0F172A" />
        </Style>
        <Style Selector="Border.bubble.codecard">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>
        <Style Selector="Border.bubble.question">
            <Setter Property="BorderBrush" Value="#C7D2FE" />
            <Setter Property="BoxShadow" Value="0 1 2 0 #0A0F172A" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F8FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#A5B4FC" />
        </Style>

        <Style Selector="TextBlock.brandmark">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Inter, sans-serif" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="-0.2" />
            <Setter Property="Foreground" Value="#080F23" />
        </Style>
        <!-- Brand tagline: letter-spaced caps under the hero mark. -->
        <Style Selector="TextBlock.tagline">
            <Setter Property="FontSize" Value="9.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="3.4" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <!-- Satellite dot slowly circles the hero mark (animates a plain double — keyframe-safe). -->
        <Style Selector="c|LumaLogo.orbitspin">
            <Style.Animations>
                <Animation Duration="0:0:9" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="OrbitAngle" Value="-55" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="OrbitAngle" Value="305" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="TextBlock.sectionlabel">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.6" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6B7280" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="Foreground" Value="#1E293B" />
        </Style>

        <Style Selector="Border.panelshell">
            <Setter Property="Background" Value="{DynamicResource PanelFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 40 0 #222563EB" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
        </Style>
        <!-- Plan mode idle rim: subtle cyan/violet aurora (busy/writing override below). -->
        <Style Selector="Border.panelshell.plan">
            <Setter Property="BorderBrush" Value="#B8A4FF" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 44 0 #332563EB, 0 0 22 0 #2238BDF8" />
        </Style>
        <Style Selector="Border.panelshell.busy">
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBusyBrush}" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 48 0 #442563EB, 0 0 24 0 #2238BDF8" />
        </Style>
        <Style Selector="Border.panelshell.writing">
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderWritingBrush}" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 36 0 #337FFFDA" />
        </Style>
        <Style Selector="Border.panelshell.busy.writing">
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderWritingBrush}" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 40 0 #447FFFDA" />
        </Style>
        <Style Selector="Border.panelshell.flash">
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBusyBrush}" />
            <Setter Property="BoxShadow" Value="0 20 50 0 #14080F23, 0 0 56 0 #662563EB" />
        </Style>

        <Style Selector="Border.infostrip">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="Border.warnstrip">
            <Setter Property="Background" Value="#FFFBEB" />
            <Setter Property="BorderBrush" Value="#FCD34D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="Border.runstrip">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#C7D2FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="Border.memorychip">
            <Setter Property="Background" Value="{DynamicResource QuietGlassBrush}" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <!-- Compose + menu trigger: soft violet coin, bottom-left of the capsule. -->
        <Style Selector="Button.composemore">
            <Setter Property="Background" Value="#F5F2FF" />
            <Setter Property="BorderBrush" Value="#E6DEFC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.composemore:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EDE7FF" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
        </Style>
        <Style Selector="Button.composemore:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E1D8FF" />
            <Setter Property="BorderBrush" Value="#A78BFF" />
        </Style>
        <!-- Compose model picker: pill next to send (provider · effort). -->
        <Style Selector="Button.composemodel">
            <Setter Property="Background" Value="#F6F4FF" />
            <Setter Property="BorderBrush" Value="#E0D8FC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.composemodel:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EDE7FF" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
        </Style>
        <Style Selector="Button.composemodel:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E1D8FF" />
            <Setter Property="BorderBrush" Value="#A78BFF" />
        </Style>
        <!-- Context tokens: violet-tinted pills that sit inside the compose capsule. -->
        <Style Selector="Border.cwdchip">
            <Setter Property="Background" Value="#F6F4FF" />
            <Setter Property="BorderBrush" Value="#E6DEFC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
        <!-- Write audit: cool lilac module. -->
        <Style Selector="Border.writeaudit">
            <Setter Property="Background" Value="{DynamicResource SurfaceGlassBrush}" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BoxShadow" Value="0 8 22 0 #1A000000, inset 0 1 0 0 #AAFFFFFF" />
        </Style>
        <Style Selector="Border.auditrow">
            <Setter Property="Background" Value="#88FFFFFF" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style Selector="Border.auditrow.focused">
            <Setter Property="Background" Value="#C7D2FE" />
            <Setter Property="BoxShadow" Value="0 0 0 1.5 #A5B4FC, 0 0 18 0 #E2E8F0" />
        </Style>
        <Style Selector="Border.kindbadge">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="#E2E8F0" />
        </Style>
        <!-- Live pair: file chips + unified line preview. -->
        <Style Selector="Border.livepair">
            <Setter Property="Background" Value="{DynamicResource SurfaceGlassBrush}" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="BoxShadow" Value="0 8 22 0 #1A000000, inset 0 1 0 0 #AAFFFFFF" />
            <Setter Property="MaxHeight" Value="280" />
        </Style>
        <Style Selector="Border.livepairbadge">
            <Setter Property="Background" Value="#5512B86A" />
            <Setter Property="BorderBrush" Value="#AA12B86A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
        <Style Selector="Button.livepairchip">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>
        <Style Selector="Button.livepairchip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#C7D2FE" />
        </Style>
        <Style Selector="Button.livepairchip.active">
            <Setter Property="Background" Value="#E0E7FF" />
            <Setter Property="BorderBrush" Value="#A5B4FC" />
            <Setter Property="Foreground" Value="#312E81" />
        </Style>
        <Style Selector="Button.livepairchip.fresh">
            <Setter Property="BorderBrush" Value="#12B86A" />
            <Setter Property="Background" Value="#E8FBF1" />
            <Setter Property="Foreground" Value="#0A6B3C" />
        </Style>
        <!-- BoxShadow is not available on Button — target the template border for a soft glow. -->
        <Style Selector="Button.livepairchip.fresh /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E8FBF1" />
            <Setter Property="BorderBrush" Value="#12B86A" />
        </Style>
        <Style Selector="Border.livepairpreview">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.livepairline">
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.livepairline.add">
            <Setter Property="Background" Value="#D8F5E6" />
        </Style>
        <Style Selector="Border.livepairline.add TextBlock">
            <Setter Property="Foreground" Value="#0A6B3C" />
        </Style>
        <Style Selector="Border.livepairline.del">
            <Setter Property="Background" Value="#FCE4E7" />
        </Style>
        <Style Selector="Border.livepairline.del TextBlock">
            <Setter Property="Foreground" Value="#B02030" />
        </Style>
        <Style Selector="Border.livepairline.ctx TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style Selector="Border.fresh">
            <Setter Property="Background" Value="#7712B86A" />
            <Setter Property="BoxShadow" Value="0 0 12 0 #5512B86A" />
        </Style>
        <!-- Heat filaments (add green / del red) — kept for any residual bindings. -->
        <Style Selector="Border.heatadd">
            <Setter Property="Height" Value="5" />
            <Setter Property="CornerRadius" Value="2.5" />
            <Setter Property="Background" Value="#CC12B86A" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style Selector="Border.heatdel">
            <Setter Property="Height" Value="5" />
            <Setter Property="CornerRadius" Value="2.5" />
            <Setter Property="Background" Value="#CCFF6B7A" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <!-- Chaos mode chips: flat glass. -->
        <Style Selector="Button.chaoschip">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.chaoschip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="Button.chaoschip:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="BorderBrush" Value="#4F46E5" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- Lean chat chip: glass pill in same family as chaos/split chips (prevents gray fallback).
             "Lean ON" label signals active; click turns off. -->
        <Style Selector="Button.leanchip">
            <Setter Property="Background" Value="#EEFFFFFF" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.leanchip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="Button.leanchip:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="BorderBrush" Value="#4F46E5" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- Plan mode chip: aurora pill (distinct from chaos/cwd). BoxShadow not on Button. -->
        <Style Selector="Button.planchip">
            <Setter Property="Background" Value="#EEF6FF" />
            <Setter Property="Foreground" Value="#4338CA" />
            <Setter Property="BorderBrush" Value="#C4B5FD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.planchip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E8F0FF" />
            <Setter Property="BorderBrush" Value="#A78BFF" />
            <Setter Property="Foreground" Value="#312E81" />
        </Style>
        <Style Selector="Button.planchip:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Ellipse.planpulse">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="#00E5FF" />
            <Style.Animations>
                <Animation Duration="0:0:1.4" IterationCount="Infinite" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.35" /><Setter Property="Fill" Value="{DynamicResource AccentBrush}" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /><Setter Property="Fill" Value="#00E5FF" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Split-brain: dual-energy module. -->
        <Style Selector="Border.splitbrain">
            <Setter Property="Background" Value="{DynamicResource SurfaceGlassBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SplitBrainBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BoxShadow" Value="0 10 24 0 #E0E7FF, inset 0 1 0 0 #CCFFFFFF" />
        </Style>
        <Style Selector="TextBlock.splitvs">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#4338CA" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0" />
        </Style>

        <!-- Compose: seamless floating capsule — the shell IS the input (no inner box).
             Rest = quiet white float; listening = aurora ring + lift. -->
        <Style Selector="Border.composeshell">
            <Setter Property="Background" Value="{DynamicResource ComposeFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ComposeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="BoxShadow" Value="0 10 30 0 #142563EB, 0 2 6 0 #08080F23, inset 0 1 0 0 #CCFFFFFF" />
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.16" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.composeshell:pointerover">
            <Setter Property="BoxShadow" Value="0 12 34 0 #1C2563EB, 0 2 6 0 #08080F23, inset 0 1 0 0 #CCFFFFFF" />
        </Style>
        <Style Selector="Border.composeshell.listening">
            <Setter Property="BorderBrush" Value="{DynamicResource ComposeBorderListeningBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BoxShadow" Value="0 0 0 1 #442563EB, 0 12 34 0 #262563EB, 0 0 24 0 #1A93C5FD, inset 0 1 0 0 #CCFFFFFF" />
        </Style>
        <!-- Inside the capsule the TextBox draws no chrome of its own, in any state. -->
        <Style Selector="Border.composeshell TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.composeshell TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.composeshell TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <!-- Send orb halo: quiet by default, aurora glow when a message is ready. -->
        <Style Selector="Border.sendhalo">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #10080F23" />
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.sendhalo.lit">
            <Setter Property="BoxShadow" Value="0 5 16 0 #4D2563EB, 0 0 20 0 #2638BDF8" />
        </Style>
        <Style Selector="Border.livepair.writing">
            <Setter Property="BorderBrush" Value="#7FFFDA" />
            <Setter Property="BoxShadow" Value="0 4 16 0 #227FFFDA" />
        </Style>

        <Style Selector="Border.heromark">
            <Setter Property="Background" Value="{DynamicResource StarMarkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BoxShadow" Value="0 12 36 0 #442563EB, 0 0 28 0 #3338BDF8" />
        </Style>
        <Style Selector="Border.heroground">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="4" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </Application.Styles>
</Application>
