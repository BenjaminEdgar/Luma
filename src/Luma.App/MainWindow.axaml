<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:Luma.App.Controls"
        x:Class="Luma.App.MainWindow"
        Width="52" Height="52" MinWidth="52" MinHeight="52"
        CanResize="True" ShowInTaskbar="False" Topmost="True"
        WindowDecorations="None" TransparencyLevelHint="Transparent"
        Background="Transparent" ExtendClientAreaToDecorationsHint="True">
  <Border Name="Shell" Background="Transparent">
    <Grid>
      <!-- Luma Aurora shell: mist glass + soft field + brand rim. -->
      <Border Name="PanelBackground" IsVisible="False" Classes="panelshell" Opacity="1"
              Classes.busy="{Binding IsBusy}"
              Classes.writing="{Binding IsLivePairWatching}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.26" Easing="CubicEaseOut" />
          </Transitions>
        </Border.Transitions>
        <Grid IsHitTestVisible="False">
          <c:GeometricPattern Classes="geopattern slow"
                              PatternColor="#2563EB" PatternOpacity="0.07"
                              CellSize="32" Shear="0.5"
                              ShowDots="False" ShowDiagonals="True" />
          <c:GeometricPattern Classes="geopattern fast"
                              PatternColor="#3B82F6" PatternOpacity="0.08"
                              CellSize="18" Shear="-0.4"
                              ShowDots="True" ShowDiagonals="False" />
          <Border Classes="ambientorb" Background="{StaticResource OrbTopBrush}"
                  Width="380" Height="300" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Margin="-100,-110,0,0" />
          <Border Classes="ambientorb mid" Background="{StaticResource OrbMidBrush}"
                  Width="300" Height="260" HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,-80,10" />
          <Border Classes="prismrim" Height="2" VerticalAlignment="Top" Margin="22,0,22,0"
                  CornerRadius="1" Background="{StaticResource PrismEdgeBrush}"
                  Classes.busy="{Binding IsBusy}" />
        </Grid>
      </Border>

      <!-- Dock: glowing aurora star. -->
      <Border Name="DockGlow" Width="52" Height="52" CornerRadius="26" HorizontalAlignment="Left"
              VerticalAlignment="Top" Margin="0" Classes="dockglow"
              Background="{StaticResource DockGlowBrush}" />
      <Border Name="DockRing" Classes="dockring" Width="48" Height="48" CornerRadius="24"
              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" BorderThickness="1.5"
              IsHitTestVisible="False">
        <Border.BorderBrush>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#CC2563EB" Offset="0" />
            <GradientStop Color="#AA38BDF8" Offset="1" />
          </LinearGradientBrush>
        </Border.BorderBrush>
      </Border>

      <Button Name="DockButton" Classes="accent" Width="44" Height="44" HorizontalAlignment="Left"
              VerticalAlignment="Top" Margin="3" CornerRadius="22" Padding="0"
              ToolTip.Tip="Open Luma — ask anything about your screen">
        <c:LumaLogo Width="22" Height="22" StarBrush="White" ShowOrbit="False" />
      </Button>

      <Grid Name="Panel" IsVisible="False" Opacity="0" RenderTransform="translateY(14px) scale(0.96)"
            Margin="22,20,20,20" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
        <Grid.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.26" Easing="CubicEaseOut" />
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut" />
          </Transitions>
        </Grid.Transitions>

        <!-- Compact header (brand board example). -->
        <Grid Grid.Row="0" Name="HeaderBar" Background="Transparent"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,14">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <!-- Alternate horizontal lockup (brand board): orbit mark + wordmark. -->
            <Button Name="LogoButton" Classes="ghost" Width="34" Height="34" CornerRadius="12"
                    Padding="0" VerticalAlignment="Center" BorderThickness="0"
                    ToolTip.Tip="Minimize to dock">
              <c:LumaLogo Width="27" Height="27" StarBrush="{StaticResource StarMarkBrush}"
                          OrbitBrush="#D93B82F6" SatelliteBrush="#2563EB" />
            </Button>
            <Border Name="DragHandle" VerticalAlignment="Center" Cursor="SizeAll"
                    Background="Transparent" Padding="0,4">
              <TextBlock Text="Luma" Classes="brandmark" />
            </Border>
          </StackPanel>
          <Border Grid.Column="2" Name="StatusPill" Classes="statuspill" VerticalAlignment="Center" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="7" Height="7" VerticalAlignment="Center" IsVisible="{Binding !IsBusy}"
                       Fill="{DynamicResource AccentBrush}" />
              <Ellipse Classes="thinkingring" Width="9" Height="9" VerticalAlignment="Center"
                       IsVisible="{Binding IsBusy}" />
              <TextBlock Text="{Binding SurfaceStatus}" FontSize="11" Foreground="#1E293B"
                         TextTrimming="CharacterEllipsis" MaxWidth="110" />
            </StackPanel>
          </Border>
          <Button Grid.Column="3" Classes="outline" Command="{Binding NewChatCommand}"
                  IsEnabled="{Binding CanStartNewChat}" Height="30" MinWidth="72"
                  Padding="12,0" CornerRadius="999" VerticalAlignment="Center" Margin="0,0,4,0"
                  ToolTip.Tip="Clear this conversation and start fresh">
            <TextBlock Text="+ New chat" FontSize="11.5" FontWeight="SemiBold"
                       VerticalAlignment="Center" Foreground="#1E293B" />
          </Button>
          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2">
            <Button Name="SettingsButton" Classes="ghost" Width="30" Height="30"
                    CornerRadius="10" Padding="0" VerticalAlignment="Center"
                    ToolTip.Tip="Settings">
              <Path Data="M4,8 L20,8 M4,16 L20,16 M14,8 m-2.4,0 a2.4,2.4 0 1 0 4.8,0 a2.4,2.4 0 1 0 -4.8,0 M9,16 m-2.4,0 a2.4,2.4 0 1 0 4.8,0 a2.4,2.4 0 1 0 -4.8,0"
                    Stroke="#6B7280" StrokeThickness="1.6" StrokeLineCap="Round" Fill="#FFF2F4FF"
                    Width="13" Height="13" Stretch="Uniform" />
            </Button>
            <Button Name="ClosePanelButton" Classes="ghost" Content="&#x00D7;"
                    Width="30" Height="30" CornerRadius="10" FontSize="16" VerticalAlignment="Center"
                    ToolTip.Tip="Minimize to dock" />
          </StackPanel>
        </Grid>

        <!-- Status: warn / compact busy detail / memory chip -->
        <StackPanel Grid.Row="1" Spacing="6" Margin="0,0,0,8">
          <Border IsVisible="{Binding HasProviderProblem}" Classes="warnstrip">
            <TextBlock Text="{Binding ProviderStatus}" FontSize="11.5" TextWrapping="Wrap"
                       Foreground="#B45309" />
          </Border>
          <Border IsVisible="{Binding ShowBusyDetail}" Classes="runstrip"
                  ToolTip.Tip="Drag the dock icon onto a target to STOP">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Classes="thinkingring" Width="11" Height="11" VerticalAlignment="Center" />
              <TextBlock Text="{Binding SurfaceDetail}" FontSize="11.5" Foreground="#1E293B"
                         TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <Border IsVisible="{Binding HasAssistantMemory}" Classes="memorychip"
                  ToolTip.Tip="{Binding AssistantMemoryPreview}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}" />
              <TextBlock Text="Memory" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Dual explain (brand board primary + secondary). -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,0,0,14"
              IsVisible="{Binding ShowScreenLandingActions}">
          <Button Grid.Column="0" Classes="accent" Command="{Binding ExplainScreenCommand}"
                  IsEnabled="{Binding IsIdle}" HorizontalAlignment="Stretch" MinHeight="52"
                  CornerRadius="999" Padding="16,12"
                  ToolTip.Tip="Capture everything on screen and explain what matters">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <c:LumaLogo Width="15" Height="15" StarBrush="White" ShowOrbit="False"
                          VerticalAlignment="Center" />
              <TextBlock Text="Explain this screen" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" Foreground="White" />
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Classes="outline actioncard" Command="{Binding ExplainSelectionCommand}"
                  IsEnabled="{Binding IsIdle}" HorizontalAlignment="Stretch" MinHeight="52"
                  CornerRadius="999" Padding="16,12"
                  ToolTip.Tip="Drag a box around the part you care about — Luma explains only that">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <Path Data="M9,4 L6,4 C4.9,4 4,4.9 4,6 L4,9 M15,4 L18,4 C19.1,4 20,4.9 20,6 L20,9 M9,20 L6,20 C4.9,20 4,19.1 4,18 L4,15 M15,20 L18,20 C19.1,20 20,19.1 20,18 L20,15"
                    Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.8" StrokeLineCap="Round"
                    Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" />
              <TextBlock Text="Explain this part" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" Foreground="#1E293B" />
            </StackPanel>
          </Button>
        </Grid>

        <!-- Chat / empty landing -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                      IsVisible="{Binding !Messages.Count}">
            <Border Classes="heromark" Width="76" Height="76" CornerRadius="38"
                    HorizontalAlignment="Center" Margin="0,4,0,0">
              <c:LumaLogo Classes="orbitspin" Width="48" Height="48" StarBrush="White"
                          OrbitBrush="#8CFFFFFF" SatelliteBrush="White"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="LET'S MAKE LIFE BETTER" Classes="tagline"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="3.4,4,0,0" />
            <TextBlock Text="{Binding LandingTitle}"
                       FontSize="18" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap"
                       MaxWidth="320" Foreground="{DynamicResource TextBrightBrush}" Margin="0,2,0,0" />
            <TextBlock Text="{Binding LandingSubtitle}"
                       FontSize="13" TextAlignment="Center" TextWrapping="Wrap"
                       MaxWidth="300" Classes="muted" LineHeight="18" />
            <!-- Repo code actions when a project folder is set. -->
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" MaxWidth="400"
                       IsVisible="{Binding ShowRepoLandingActions}" Margin="0,4,0,0">
              <Button Classes="chip" Content="Inspect diff" Margin="0,0,6,6"
                      Command="{Binding UseCodeActionCommand}"
                      CommandParameter="Inspect the current repo changes and suggest the next safest code change."
                      IsEnabled="{Binding IsIdle}"
                      ToolTip.Tip="Review working tree context before changing files" />
              <Button Classes="chip" Content="Test + fix" Margin="0,0,6,6"
                      Command="{Binding UseCodeActionCommand}"
                      CommandParameter="Run the appropriate tests for this repo, diagnose failures, and make the smallest needed fix."
                      IsEnabled="{Binding IsIdle}"
                      ToolTip.Tip="Run or infer the repo test command, then fix failures" />
              <Button Classes="chip" Content="Refactor" Margin="0,0,6,6"
                      Command="{Binding UseCodeActionCommand}"
                      CommandParameter="Refactor the focused area with a small patch, preserve behavior, and add or update tests if useful."
                      IsEnabled="{Binding IsIdle}"
                      ToolTip.Tip="Ask for a conservative refactor in the attached repo" />
            </WrapPanel>
            <Border IsVisible="{Binding ShowGlobalExplainHint}" Classes="infostrip"
                    Padding="10,5" HorizontalAlignment="Center" Margin="0,2,0,0">
              <TextBlock Text="Ctrl+Shift+E  ·  select &amp; explain from any app"
                         FontSize="10.5" Foreground="#64748B" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                        IsVisible="{Binding IsSuggesting}" Margin="0,4,0,0">
              <Ellipse Classes="thinkingring" Width="12" Height="12" />
              <TextBlock Text="{Binding SurfaceDetail}" FontSize="11.5" Classes="muted"
                         VerticalAlignment="Center" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding Suggestions}" HorizontalAlignment="Center"
                          MaxWidth="420" Margin="0,2,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="chip" Content="{Binding}" Margin="0,0,6,6"
                          Click="OnSuggestionClick" ToolTip.Tip="Send this — one click" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Disabled horizontal scroll forces a finite width down into bubbles so text wraps. -->
          <ScrollViewer Name="ChatScroll" VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding Messages.Count}" ClipToBounds="True"
                        Padding="1,0,4,0">
            <ItemsControl ItemsSource="{Binding Messages}">
              <ItemsControl.Styles>
                <Style Selector="ItemsControl > ContentPresenter">
                  <Setter Property="HorizontalAlignment" Value="Stretch" />
                </Style>
              </ItemsControl.Styles>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="bubble" Classes.user="{Binding IsUser}" Classes.error="{Binding IsError}"
                          Classes.codecard="{Binding HasCodeSession}"
                          Classes.question="{Binding ShowQuestionCard}"
                          MaxWidth="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding Caption, Converter={x:Static ObjectConverters.IsNotNull}}">
                          <TextBlock Text="{Binding Caption}" FontSize="11" Foreground="{DynamicResource AccentSoftBrush}"
                                     VerticalAlignment="Center" FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1" Text="{Binding Elapsed}" FontSize="10.5"
                                     Foreground="#886B6490" VerticalAlignment="Center" Margin="7,0,0,0" />
                        </Grid>
                        <Border Classes="turnmeta" IsVisible="{Binding HasTurnMeta}">
                          <TextBlock Text="{Binding TurnMeta}" FontSize="10.5" Foreground="#64748B"
                                     TextTrimming="CharacterEllipsis" />
                        </Border>
                        <!-- Tiny screenshot chip — glanceable, not a full-size preview. -->
                        <Border IsVisible="{Binding HasImage}" Classes="chatimage" Margin="0,2,0,4"
                                HorizontalAlignment="Left">
                          <Grid>
                            <Image Source="{Binding AttachmentImage}" Stretch="Uniform"
                                   MaxWidth="120" MaxHeight="72" HorizontalAlignment="Left" />
                            <Border Classes="chatimagelabel" HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom" Margin="5"
                                    IsVisible="{Binding ImageLabel, Converter={x:Static ObjectConverters.IsNotNull}}">
                              <TextBlock Text="{Binding ImageLabel}" FontSize="9.5" Foreground="#334155" />
                            </Border>
                          </Grid>
                        </Border>
                        <c:MarkdownView Markdown="{Binding Text}" IsVisible="{Binding !IsPending}"
                                        HorizontalAlignment="Stretch" />
                        <!-- Shared speaking line for every provider: thinking + streaming. -->
                        <Border Classes="streamshimmer" HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsSpeaking}" />

                        <!-- In-chat clarifying question card -->
                        <Border IsVisible="{Binding ShowQuestionCard}" Classes="questioncard" Margin="0,8,0,2">
                          <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <Border Classes="questionbadge" Width="28" Height="28" CornerRadius="9">
                                <c:LumaLogo Width="14" Height="14" StarBrush="White" ShowOrbit="False"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Border>
                              <StackPanel Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="QUICK QUESTION" Classes="sectionlabel" />
                                <TextBlock Text="Answer below to continue" FontSize="11" Classes="muted" />
                              </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{Binding Question}" Classes="questionprompt"
                                       TextWrapping="WrapWithOverflow" />

                            <ItemsControl ItemsSource="{Binding QuestionChoices}"
                                          IsVisible="{Binding HasQuestionChoices}"
                                          Tag="{Binding}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Button Classes="qchoice" Content="{Binding}"
                                          Tag="{Binding $parent[ItemsControl].Tag}"
                                          Click="OnQuestionChoiceClick"
                                          Margin="0,0,7,7"
                                          ToolTip.Tip="Choose this answer" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <TextBox Classes="qanswer" Text="{Binding QuestionAnswer}"
                                       PlaceholderText="Or type your own answer…"
                                       AcceptsReturn="False" MinHeight="40"
                                       KeyDown="OnQuestionAnswerKeyDown" />
                              <Button Grid.Column="1" Classes="accent qsend" Content="Send"
                                      Width="64" Height="40" CornerRadius="12" Padding="0"
                                      VerticalAlignment="Stretch"
                                      Command="{Binding $parent[Window].DataContext.AnswerQuestionCommand}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="Send answer" />
                            </Grid>

                            <Button Classes="ghost qskip" Content="Continue without this"
                                    HorizontalAlignment="Left" Padding="10,6" CornerRadius="10"
                                    Command="{Binding $parent[Window].DataContext.SkipQuestionCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="Skip and let Luma continue without this detail" />
                          </StackPanel>
                        </Border>

                        <!-- Ghost cursor: point at the screen -->
                        <Button Classes="outline" Content="{Binding ShowWhereButtonLabel}"
                                IsVisible="{Binding HasShowWhere}"
                                HorizontalAlignment="Left" Margin="0,6,0,2"
                                Padding="12,6" CornerRadius="10" FontSize="12"
                                Command="{Binding $parent[Window].DataContext.ShowWhereCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Pulse a highlight on the real screen" />

                        <!-- Split-brain merge card -->
                        <Border IsVisible="{Binding HasSplitBrain}" Classes="splitbrain" Margin="0,8,0,2">
                          <StackPanel Spacing="8">
                            <TextBlock Text="SPLIT-BRAIN" Classes="sectionlabel" />
                            <TextBlock FontSize="12" Classes="muted" TextWrapping="Wrap"
                                       Text="Two answers. Keep the explainer, the implementer, or both." />
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding SplitBrain.CanChoose}">
                              <Button Classes="accent" Padding="12,6" CornerRadius="10" FontSize="12"
                                      Content="{Binding SplitBrain.ProviderA, StringFormat=Keep {0}}"
                                      Command="{Binding $parent[Window].DataContext.ChooseSplitBrainCommand}"
                                      CommandParameter="{Binding}"
                                      Tag="A"
                                      Click="OnSplitBrainKeepClick" />
                              <TextBlock Text="VS" Classes="splitvs" />
                              <Button Classes="outline" Padding="12,6" CornerRadius="10" FontSize="12"
                                      Content="{Binding SplitBrain.ProviderB, StringFormat=Keep {0}}"
                                      Click="OnSplitBrainKeepClick" Tag="B" />
                              <Button Classes="ghost" Padding="12,6" CornerRadius="10" FontSize="12"
                                      Content="Keep both" Click="OnSplitBrainKeepClick" Tag="Both" />
                            </StackPanel>
                            <TextBlock IsVisible="{Binding SplitBrain.HasChosen}" FontSize="12"
                                       Foreground="{DynamicResource AccentSoftBrush}"
                                       Text="{Binding SplitBrain.Chosen, StringFormat=Kept: {0}}" />
                          </StackPanel>
                        </Border>

                        <!-- Agent write audit with per-file undo -->
                        <Border IsVisible="{Binding HasFileChanges}" Classes="writeaudit" Margin="0,8,0,2">
                          <StackPanel Spacing="8">
                            <TextBlock Text="FILES CHANGED" Classes="sectionlabel" />
                            <ItemsControl ItemsSource="{Binding FileChanges}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Border Classes="auditrow" Classes.focused="{Binding IsFocused}"
                                          Margin="0,0,0,4" Padding="6,4" CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                      <Border Classes="kindbadge" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KindLabel}" FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#334155" />
                                      </Border>
                                      <TextBlock Grid.Column="1" Text="{Binding Summary}" FontSize="12"
                                                 TextWrapping="WrapWithOverflow" VerticalAlignment="Center"
                                                 Foreground="#334155" />
                                      <Button Grid.Column="2" Classes="outline" Content="Undo"
                                              Padding="10,4" CornerRadius="8" FontSize="11"
                                              IsVisible="{Binding CanUndo}"
                                              Command="{Binding $parent[Window].DataContext.UndoFileChangeCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="Restore this file to its pre-turn content" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <!-- Digest / extra action chips on a message -->
                        <ItemsControl ItemsSource="{Binding ActionChips}" IsVisible="{Binding HasActionChips}"
                                      Margin="0,6,0,0">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Button Classes="chip" Content="{Binding}" Margin="0,0,7,7"
                                      Command="{Binding $parent[Window].DataContext.UseSuggestionCommand}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="Send this" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <c:DiffCardControl Session="{Binding CodeSession}" IsVisible="{Binding HasCodeSession}"
                                           Margin="0,6,0,0" HorizontalAlignment="Stretch" />

                        <Button Classes="msgcopy" Content="Copy" HorizontalAlignment="Right"
                                IsVisible="{Binding !IsUser}" ToolTip.Tip="Copy answer"
                                Margin="0,2,0,0"
                                Command="{Binding $parent[ItemsControl].DataContext.CopyMessageCommand}"
                                CommandParameter="{Binding}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>

        <!-- Live coding pair: file chips + unified line preview while the agent writes -->
        <Border Grid.Row="4" Classes="livepair" Margin="0,0,0,10"
                IsVisible="{Binding ShowLivePair}"
                Classes.writing="{Binding IsLivePairWatching}">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <StackPanel Spacing="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                           IsVisible="{Binding IsLivePairWatching}">
                    <Ellipse.Fill>
                      <SolidColorBrush Color="#12B86A" />
                    </Ellipse.Fill>
                  </Ellipse>
                  <TextBlock Text="{Binding LivePairTitle}" Classes="sectionlabel"
                             VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding LivePairSubtitle}" FontSize="11" Classes="muted"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <Border Grid.Column="1" Classes="livepairbadge" VerticalAlignment="Center"
                      IsVisible="{Binding IsLivePairWatching}">
                <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="#0A8F52" />
              </Border>
              <Button Grid.Column="2" Classes="ghost" Content="×" Width="28" Height="28"
                      Padding="0" CornerRadius="8" FontSize="14" VerticalAlignment="Center"
                      Command="{Binding DismissLivePairCommand}"
                      ToolTip.Tip="Dismiss live diff" />
            </Grid>

            <!-- File chips: pick which file's live output to show -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          IsVisible="{Binding HasLivePair}">
              <ItemsControl ItemsSource="{Binding LivePairFiles}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="livepairchip"
                            Classes.active="{Binding IsActive}"
                            Classes.fresh="{Binding IsFresh}"
                            Command="{Binding $parent[Window].DataContext.JumpLivePairCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding Summary}">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding KindLabel}" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" Opacity="0.75" />
                        <TextBlock Text="{Binding DisplayName}" FontSize="11.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MaxWidth="140"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StatsLabel}" FontSize="10.5"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   VerticalAlignment="Center" Opacity="0.85" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Live unified-diff output for the active file -->
            <Border Classes="livepairpreview" IsVisible="{Binding HasLivePairPreview}">
              <ScrollViewer x:Name="LivePairPreviewScroll" MaxHeight="168"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding LivePairPreviewLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="livepairline"
                              Classes.add="{Binding IsAdded}"
                              Classes.del="{Binding IsRemoved}"
                              Classes.ctx="{Binding IsContext}">
                        <TextBlock Text="{Binding Display}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="11.5"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <TextBlock Text="Waiting for the first write…" FontSize="11" Classes="muted"
                       IsVisible="{Binding !HasLivePair}"
                       Margin="2,0,0,0" />
          </StackPanel>
        </Border>

        <!-- Follow-up chips (no section label — chips speak for themselves) -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8" Spacing="6">
          <ItemsControl ItemsSource="{Binding Suggestions}" IsVisible="{Binding Messages.Count}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="chip" Content="{Binding}" Click="OnSuggestionClick"
                        Margin="0,0,6,6" ToolTip.Tip="Send this reply" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsSuggesting}">
            <Ellipse Classes="thinkingring" Width="11" Height="11" />
            <TextBlock Text="Refining quick actions…" FontSize="11" Classes="muted" />
          </StackPanel>
        </StackPanel>

        <!-- Compose bar — seamless brand capsule; the shell IS the input.
             "listening" class toggled from code-behind on QuestionBox focus. -->
        <Border Grid.Row="6" Name="ComposeShell" Classes="composeshell">
          <Grid RowDefinitions="Auto,*" RowSpacing="2">
            <!-- Context chips: project folder, clipboard, attached files -->
            <WrapPanel Orientation="Horizontal">
              <Border Classes="cwdchip" IsVisible="{Binding HasWorkingDirectory}" Margin="0,0,6,4"
                      ToolTip.Tip="{Binding WorkingDirectoryTip}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Data="M3,6 L10,6 L12,8.5 L21,8.5 L21,18 L3,18 Z"
                        Stroke="{DynamicResource AccentSoftBrush}" StrokeThickness="1.5" StrokeJoin="Round"
                        Width="12" Height="11" Stretch="Uniform" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding WorkingDirectoryLabel}" FontSize="11.5"
                             Foreground="#334155" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" MaxWidth="160" />
                </StackPanel>
              </Border>
              <Border Classes="cwdchip" IsVisible="{Binding HasClipboardSnippet}" Margin="0,0,6,4"
                      ToolTip.Tip="Clipboard will be sent with your next message">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Clipboard" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentSoftBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ClipboardSnippetPreview}" FontSize="11"
                             Foreground="#334155" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" MaxWidth="140" />
                  <Button Classes="ghost" Content="×" Width="20" Height="20" Padding="0" FontSize="12"
                          Command="{Binding ClearClipboardCommand}" ToolTip.Tip="Remove clipboard context" />
                </StackPanel>
              </Border>
              <ItemsControl ItemsSource="{Binding AttachedFileLabels}" IsVisible="{Binding HasAttachedFiles}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="cwdchip" Margin="0,0,6,4" ToolTip.Tip="Attached for next message">
                      <TextBlock Text="{Binding}" FontSize="11" Foreground="#334155"
                                 TextTrimming="CharacterEllipsis" MaxWidth="160" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Classes="ghost" Content="Clear files" FontSize="11" Padding="8,2"
                      IsVisible="{Binding HasAttachedFiles}"
                      Command="{Binding ClearAttachedFilesCommand}"
                      VerticalAlignment="Center" Margin="0,0,0,4" />
              <!-- Compact mode chips (roast/argue live in + menu) -->
              <Button Classes="leanchip" Content="{Binding LeanChatChipLabel}" Margin="0,0,6,4"
                      IsVisible="{Binding LeanChatEnabled}"
                      Command="{Binding ToggleLeanChatCommand}"
                      ToolTip.Tip="Lean chat is on — shorter prompts &amp; history. Click to turn off." />
              <Button Classes="chaoschip" Content="{Binding ChaosToneChipLabel}" Margin="0,0,6,4"
                      IsVisible="{Binding ChaosModeEnabled}"
                      Command="{Binding CycleChaosToneCommand}"
                      ToolTip.Tip="Cycle tone: Normal → ELI5 → Staff eng" />
              <Button Classes="chaoschip" Content="{Binding PomodoroLabel}" Margin="0,0,6,4"
                      IsVisible="{Binding ChaosModeEnabled}"
                      Command="{Binding TogglePomodoroCommand}"
                      ToolTip.Tip="Focus lock blocks Explain until the timer ends" />
              <Button Classes="chaoschip" Content="{Binding SplitBrainChipLabel}" Margin="0,0,6,4"
                      IsVisible="{Binding SplitBrainEnabled}"
                      Command="{Binding ToggleSplitBrainCommand}"
                      ToolTip.Tip="Split-brain is on — next send runs explainer + implementer. Click to turn off." />
              <Button Classes="planchip" Margin="0,0,6,4"
                      IsVisible="{Binding PlanChipVisible}"
                      Command="{Binding TogglePlanWindowCommand}"
                      ToolTip.Tip="Collapse or expand the plan window. Turn plan mode off from the + menu.">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <!-- Checklist / map-path glyph -->
                  <Path Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center"
                        Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M2,3 H9 M2,6 H9 M2,9 H6 M1.5,3 V9.5" />
                  <TextBlock Text="{Binding PlanModeChipLabel}" FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <!-- Small chevron affordance: ▾ when expanded (click collapses), ▴ when collapsed (click expands). -->
                  <Path Width="7" Height="7" Stretch="Uniform" VerticalAlignment="Center" Margin="0,1,0,0"
                        Stroke="#64748B" StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M1,2 L3.5,4.5 L6,2" IsVisible="{Binding !IsPlanWindowCollapsed}" />
                  <Path Width="7" Height="7" Stretch="Uniform" VerticalAlignment="Center" Margin="0,1,0,0"
                        Stroke="#64748B" StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M1,4.5 L3.5,2 L6,4.5" IsVisible="{Binding IsPlanWindowCollapsed}" />
                  <Ellipse Classes="planpulse" />
                </StackPanel>
              </Button>
              <Button Classes="accent" Content="Implement plan" Margin="0,0,6,4" Padding="10,4"
                      IsVisible="{Binding PlanModeEnabled}"
                      Command="{Binding ImplementPlanCommand}"
                      FontSize="11" CornerRadius="999"
                      ToolTip.Tip="Run the approved plan as a coding turn in this chat" />
            </WrapPanel>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
              <!-- + menu: explain, project, clipboard, files, chaos -->
              <Button Name="ComposePlusButton" Classes="composemore" Width="34" Height="34"
                      CornerRadius="999" Padding="0" VerticalAlignment="Bottom" Margin="0,0,0,3"
                      ToolTip.Tip="More actions">
                <Button.Flyout>
                  <MenuFlyout Placement="TopEdgeAlignedLeft">
                    <MenuItem Header="Explain this screen"
                              Command="{Binding ExplainScreenCommand}"
                              ToolTip.Tip="Capture everything visible and explain" />
                    <MenuItem Header="Explain this part"
                              Command="{Binding ExplainSelectionCommand}"
                              ToolTip.Tip="Drag a region to focus the explanation" />
                    <MenuItem Header="Improve prompt"
                              Command="{Binding ImprovePromptCommand}"
                              ToolTip.Tip="Rewrite your draft for clarity — does not send" />
                    <MenuItem Header="-" />
                    <MenuItem Header="Set working directory…"
                              Click="OnSetWorkingDirectoryClick"
                              ToolTip.Tip="Choose a project folder agents can read and edit" />
                    <MenuItem Header="Clear working directory"
                              Click="OnClearWorkingDirectoryClick"
                              IsVisible="{Binding HasWorkingDirectory}"
                              ToolTip.Tip="Stop attaching a project folder to chat turns" />
                    <MenuItem Header="Use clipboard as context"
                              Command="{Binding UseClipboardCommand}"
                              ToolTip.Tip="Send whatever is on the clipboard with your next message" />
                    <MenuItem Header="Attach file…"
                              Click="OnAttachFileClick"
                              ToolTip.Tip="Pin a file's contents into the next message" />
                    <MenuItem Header="Clear attachments"
                              Command="{Binding ClearAttachedFilesCommand}"
                              IsVisible="{Binding HasAttachedFiles}" />
                    <MenuItem Header="-" />
                    <MenuItem Header="{Binding LeanChatMenuLabel}"
                              Command="{Binding ToggleLeanChatCommand}"
                              ToolTip.Tip="Shorter system prompts and tighter history to save tokens" />
                    <MenuItem Header="{Binding ChaosModeMenuLabel}"
                              Command="{Binding ToggleChaosModeCommand}"
                              ToolTip.Tip="Roast, debate, tone flip, and evil focus lock" />
                    <MenuItem Header="Roast my UI"
                              Command="{Binding RoastUiCommand}"
                              IsVisible="{Binding ChaosModeEnabled}"
                              ToolTip.Tip="Witty roast of the current screen + 3 fixes" />
                    <MenuItem Header="Argue with yourself"
                              Command="{Binding ArgueWithYourselfCommand}"
                              IsVisible="{Binding ChaosModeEnabled}"
                              ToolTip.Tip="Two providers debate (or one model plays both sides)" />
                    <MenuItem Header="{Binding PomodoroMenuLabel}"
                              Command="{Binding TogglePomodoroCommand}"
                              IsVisible="{Binding ChaosModeEnabled}" />
                    <MenuItem Header="{Binding SplitBrainMenuLabel}"
                              Command="{Binding ToggleSplitBrainCommand}"
                              ToolTip.Tip="Dual-provider explain + implement on the next send" />
                    <MenuItem Header="{Binding PlanModeMenuLabel}"
                              Command="{Binding TogglePlanModeCommand}"
                              ToolTip.Tip="Plan in chat with questions; live plan in a separate window; Implement when ready" />
                    <MenuItem Header="MCP Marketplace…"
                              Click="OnMcpMarketplaceClick"
                              ToolTip.Tip="Browse and install MCP servers for Grok" />
                  </MenuFlyout>
                </Button.Flyout>
                <Path Data="M12,5 L12,19 M5,12 L19,12" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                      StrokeLineCap="Round" Width="13" Height="13" Stretch="Uniform" />
              </Button>

              <TextBox Grid.Column="1" Name="QuestionBox" Text="{Binding Question}" AcceptsReturn="True"
                       PlaceholderText="{Binding ComposePlaceholder}"
                       MinHeight="40" MaxHeight="132" TextWrapping="Wrap" FontSize="14"
                       Foreground="{DynamicResource TextBrightBrush}" CaretBrush="{DynamicResource AccentBrush}" SelectionBrush="#332563EB"
                       VerticalContentAlignment="Center"
                       Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                       Padding="8,9" />
              <!-- Model + effort picker (right of input, left of send). -->
              <Button Grid.Column="2" Name="ComposeModelButton" Classes="composemodel"
                      Height="32" MinWidth="0" Padding="10,0,8,0" CornerRadius="999"
                      VerticalAlignment="Bottom" Margin="0,0,0,4"
                      ToolTip.Tip="Provider and reasoning effort">
                <Button.Flyout>
                  <MenuFlyout Placement="TopEdgeAlignedRight">
                    <MenuItem Header="Provider" IsEnabled="False" />
                    <MenuItem Header="{Binding ProviderMenuClaude}"
                              Command="{Binding SelectProviderCommand}" CommandParameter="0" />
                    <MenuItem Header="{Binding ProviderMenuCodex}"
                              Command="{Binding SelectProviderCommand}" CommandParameter="1" />
                    <MenuItem Header="{Binding ProviderMenuGrok}"
                              Command="{Binding SelectProviderCommand}" CommandParameter="2" />
                    <MenuItem Header="-" />
                    <MenuItem Header="Effort" IsEnabled="False" />
                    <MenuItem Header="{Binding EffortMenuLow}"
                              Command="{Binding SelectEffortCommand}" CommandParameter="0"
                              ToolTip.Tip="Faster, lighter answers (Codex reasoning)" />
                    <MenuItem Header="{Binding EffortMenuMedium}"
                              Command="{Binding SelectEffortCommand}" CommandParameter="1"
                              ToolTip.Tip="Balanced reasoning" />
                    <MenuItem Header="{Binding EffortMenuHigh}"
                              Command="{Binding SelectEffortCommand}" CommandParameter="2"
                              ToolTip.Tip="Deeper reasoning when it matters" />
                  </MenuFlyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="{Binding ModelPickerLabel}" FontSize="11.5" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center" />
                  <Path Data="M6,9 L12,15 L18,9" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.6"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Width="9" Height="6" Stretch="Uniform" VerticalAlignment="Center"
                        Opacity="0.75" />
                </StackPanel>
              </Button>
              <Grid Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,1,1">
                <Border Classes="sendhalo" IsVisible="{Binding !IsBusy}"
                        Classes.lit="{Binding CanSend}">
                  <Button Classes="accent sendstar" Command="{Binding SendCommand}" IsEnabled="{Binding CanSend}"
                          Width="38" Height="38" CornerRadius="19"
                          Padding="0" ToolTip.Tip="Send">
                    <c:LumaLogo Width="17" Height="17" StarBrush="White" ShowOrbit="False"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Button>
                </Border>
                <Button Classes="stop" Command="{Binding StopCommand}" IsVisible="{Binding IsBusy}"
                        Width="38" Height="38" CornerRadius="19" Padding="0" ToolTip.Tip="Stop">
                  <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#C42B3A" />
                </Button>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <Border Name="ResizeGrip" Width="18" Height="18" Background="Transparent" IsVisible="False"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
              Cursor="BottomRightCorner" ToolTip.Tip="Drag to resize">
        <Path Data="M12,4 L4,12 M12,8 L8,12" Stroke="#93C5FD" StrokeThickness="1.6"
              StrokeLineCap="Round" />
      </Border>
    </Grid>
  </Border>
</Window>
